/* pages/admin-products/admin-products.wxss */
.page { display: flex; flex-direction: column; height: 100vh; background: var(--bg); }

/* 顶部栏 */
.toolbar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--white);
  gap: 16rpx;
  border-bottom: 1rpx solid var(--border);
}
.toolbar-search { flex: 1; }
.search-field {
  background: var(--bg);
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  height: 60rpx;
}

/* 统计条 */
.stats-bar {
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  background: var(--white);
  border-bottom: 1rpx solid var(--border);
}
.stats-div { margin: 0 12rpx; color: var(--border); }
.stats-onsale { color: var(--primary); }
.stats-off { color: var(--text-muted); }

/* 商品列表 */
.product-scroll { flex: 1; padding: 16rpx 20rpx; }

.prod-item {
  display: flex;
  background: var(--white);
  border-radius: var(--radius-lg);
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow);
}

/* 图片 */
.prod-img-wrap { width: 180rpx; height: 180rpx; flex-shrink: 0; }
.prod-img { width: 100%; height: 100%; }
.prod-img-empty {
  width: 100%; height: 100%;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}
.img-empty-icon { font-size: 40rpx; }
.img-empty-text { font-size: 20rpx; color: var(--text-muted); }

/* 商品信息 */
.prod-body { flex: 1; padding: 16rpx 20rpx; min-width: 0; }
.prod-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 6rpx; }
.prod-name { font-size: 28rpx; font-weight: 600; flex: 1; }
.status-tag { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx; flex-shrink: 0; }
.status-tag.on { background: var(--primary-light); color: var(--primary); }
.status-tag.off { background: #f0f0f0; color: var(--text-muted); }
.prod-cate { font-size: 22rpx; color: var(--text-muted); }
.prod-stock { font-size: 22rpx; color: var(--text-muted); }
.prod-sales { font-size: 22rpx; color: var(--text-muted); }
.price-row { margin-bottom: 10rpx; }
.prod-price { font-size: 36rpx; font-weight: 700; color: var(--danger); }
.prod-ori-price { font-size: 24rpx; color: var(--text-muted); text-decoration: line-through; }

/* 操作按钮 */
.prod-actions { display: flex; gap: 12rpx; }
.action-btn {
  flex: 1;
  padding: 10rpx 0;
  font-size: 24rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--border);
  background: var(--bg);
  color: var(--text-secondary);
  text-align: center;
}
.action-btn:active { opacity: 0.7; }
.action-btn.warn { color: var(--danger); border-color: #fcc; background: #fef0f0; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: var(--text-muted); }
