/* pages/checkout/checkout.wxss */
.page { padding-bottom: 140rpx; background: var(--bg); min-height: 100vh; }

.section {
  background: var(--white);
  margin: 16rpx 20rpx;
  border-radius: var(--radius-lg);
  padding: 24rpx;
}

/* 地址 */
.address { display: flex; align-items: center; }
.addr-row { display: flex; align-items: center; gap: 16rpx; flex: 1; }
.addr-contact { font-size: 30rpx; font-weight: 600; }
.addr-detail { font-size: 26rpx; color: var(--text-secondary); flex: 1; }
.addr-hint { font-size: 28rpx; color: var(--text-muted); flex: 1; }
.arrow { font-size: 36rpx; color: var(--text-muted); flex-shrink: 0; }

/* 商品清单 */
.goods-item { display: flex; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid var(--border); }
.goods-item:last-child { border-bottom: none; }
.goods-img { width: 100rpx; height: 100rpx; border-radius: var(--radius-sm); flex-shrink: 0; }
.goods-img-placeholder {
  width: 100rpx; height: 100rpx; border-radius: var(--radius-sm); flex-shrink: 0;
  background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 40rpx;
}
.goods-info { flex: 1; min-width: 0; }
.goods-name { font-size: 26rpx; line-height: 1.4; height: 72rpx; display: block; }
.goods-row { display: flex; justify-content: space-between; align-items: center; margin-top: 6rpx; }
.goods-qty { font-size: 24rpx; color: var(--text-muted); }

/* 金额 */
.amount-row { display: flex; justify-content: space-between; margin-bottom: 12rpx; font-size: 26rpx; }
.amount-row.total { font-size: 30rpx; font-weight: 700; padding-top: 16rpx; border-top: 1rpx solid var(--border); margin-bottom: 0; }
.free { color: var(--primary); }

/* 支付方式 */
.section-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.pay-option {
  display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid var(--border);
}
.pay-option:last-child { border-bottom: none; }
.pay-icon { font-size: 36rpx; margin-right: 16rpx; }
.pay-label { flex: 1; font-size: 28rpx; }
.pay-check { font-size: 32rpx; color: var(--primary); font-weight: 700; width: 40rpx; text-align: center; }

/* 底部栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; padding: 16rpx 24rpx;
  background: var(--white); box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06); gap: 16rpx;
}
.bar-total { flex: 1; text-align: right; padding-right: 16rpx; font-size: 28rpx; }

/* 支付弹窗 */
.pay-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 999;
}
.pay-modal {
  background: var(--white); border-radius: var(--radius-lg); padding: 48rpx;
  width: 560rpx; text-align: center;
}
.pay-modal-title { font-size: 32rpx; font-weight: 600; display: block; margin-bottom: 24rpx; }
.pay-modal-amount { font-size: 64rpx; font-weight: 800; color: var(--danger); display: block; margin-bottom: 8rpx; }
.pay-modal-way { font-size: 26rpx; color: var(--text-muted); display: block; margin-bottom: 40rpx; }
.pay-modal-cancel { display: block; margin-top: 20rpx; font-size: 26rpx; color: var(--text-muted); }
