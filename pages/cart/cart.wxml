<!-- pages/cart/cart.wxml -->
<view class="page">
  <!-- 有商品时 -->
  <block wx:if="{{!isEmpty}}">
    <view class="cart-list">
      <view class="cart-item" wx:for="{{cart}}" wx:key="*this" wx:if="{{item.qty > 0}}">
        <view class="checkbox {{item.checked ? 'checked' : ''}}" bindtap="toggleCheck" data-id="{{item.productId}}">
          <text wx:if="{{item.checked}}">✓</text>
        </view>

        <image wx:if="{{item.image}}" class="item-img" src="{{item.image}}" mode="aspectFill"/>
        <view wx:else class="item-img-placeholder">
          <text>☕</text>
        </view>

        <view class="item-info">
          <text class="item-name text-ellipsis-2">{{item.name}}</text>
          <view class="item-row">
            <text class="price">{{item.priceDisplay}}</text>
            <view class="qty-ctrl">
              <view class="qty-btn {{item.qty <= 1 ? 'disabled' : ''}}" bindtap="changeQty" data-id="{{item.productId}}" data-delta="-1">−</view>
              <text class="qty-val">{{item.qty || 0}}</text>
              <view class="qty-btn {{item.qty >= item.stock ? 'disabled' : ''}}" bindtap="changeQty" data-id="{{item.productId}}" data-delta="1">＋</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部结算：仅当有选中商品时显示 -->
    <view class="bottom-bar safe-bottom" wx:if="{{checkedCount > 0}}">
      <view class="bar-left" bindtap="toggleAll">
        <view class="checkbox {{allChecked ? 'checked' : ''}}">
          <text wx:if="{{allChecked}}">✓</text>
        </view>
        <text>全选</text>
      </view>
      <view class="bar-total">
        <text>合计：</text>
        <text class="price" style="font-size: 36rpx;">{{totalAmountDisplay}}</text>
      </view>
      <button class="btn btn-primary" bindtap="goCheckout">
        结算({{checkedCount}})
      </button>
    </view>
  </block>

  <!-- 购物车为空 -->
  <view wx:else class="empty-state">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车空空如也</text>
    <button class="btn btn-primary" style="margin-top: 40rpx;" bindtap="goOrder">去点单</button>
  </view>
</view>
