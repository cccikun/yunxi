/* pages/cart/cart.wxss */
.page { padding-bottom: 120rpx; min-height: 100vh; }

.cart-list { padding: 16rpx 20rpx; }

.cart-item {
  display: flex;
  align-items: center;
  background: var(--white);
  margin-bottom: 12rpx;
  padding: 20rpx;
  border-radius: var(--radius-md);
  gap: 16rpx;
}

.checkbox {
  width: 40rpx; height: 40rpx;
  border: 3rpx solid #ddd;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}
.checkbox.checked {
  background: var(--primary);
  border-color: var(--primary);
}

.item-img { width: 120rpx; height: 120rpx; border-radius: var(--radius-sm); flex-shrink: 0; }
.item-img-placeholder {
  width: 120rpx; height: 120rpx;
  border-radius: var(--radius-sm);
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.item-info { flex: 1; min-width: 0; }
.item-name { font-size: 28rpx; line-height: 1.4; height: 78rpx; }
.item-row { display: flex; justify-content: space-between; align-items: center; margin-top: 8rpx; }

.qty-ctrl { display: flex; align-items: center; gap: 4rpx; }
.qty-btn {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: var(--bg);
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; font-weight: 600;
}
.qty-btn.disabled { opacity: 0.3; }
.qty-val { min-width: 56rpx; text-align: center; font-size: 28rpx; font-weight: 600; }

/* 底部栏 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center;
  padding: 16rpx 24rpx;
  background: var(--white);
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  gap: 16rpx;
}
.bar-left { display: flex; align-items: center; gap: 10rpx; font-size: 26rpx; }
.bar-total { flex: 1; text-align: right; padding-right: 16rpx; font-size: 28rpx; }
